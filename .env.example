# IoT Edge Gateway — Environment Variables
# Copy this file to .env.local and fill in your values

# Database
DATABASE_URL=file:./db/iot-gateway.db

# Application
NEXT_PUBLIC_APP_NAME=IoT Edge Gateway
NEXT_PUBLIC_APP_VERSION=1.0.0

# WebSocket Broker (internal, port 8503)
WS_BROKER_PORT=8503

# Modbus Simulator (internal, port 8502)
MODBUS_SIMULATOR_PORT=8502

# MQTT Bridge (internal, port 8504)
MQTT_BRIDGE_PORT=8504
